{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "@nick-vi/type-inject-mcp",
    "@tarquinen/opencode-dcp@latest",
    "opencode-pty",
    "@franlol/opencode-md-table-formatter@latest",
    "@gotgenes/opencode-agent-identity",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "cc-safety-net",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest",
    "@streetturtle/opencode-context-progress",
    "@streetturtle/opencode-session-tokens",
    "oh-my-opencode-slim"
  ],
  "instructions": [
    "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "coderag": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sylphx/coderag-mcp"
      ],
      "environment": {
        "OPENAI_API_KEY": "",
        "CODEBASE_ROOT": "",
        "INDEX_PATH": ".coderag"
      }
    },
    "pdf-reader": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "vue-mcp": {
      "type": "remote",
      "url": "https://mcp.vue-mcp.org/mcp"
    }
  },
  "provider": {
    "spark": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SPARKIE",
      "options": {
        "baseURL": "http://100.80.227.55:8000/v1",
        "chunkTimeout": 18000000,
        "apiKey": ""
      },
      "models": {
        "Qwen/Qwen3-Coder-Next-FP8": {
          "name": "Qwen3 Coder Next FP8",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "orchestrator": {
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "lsp": true
}
